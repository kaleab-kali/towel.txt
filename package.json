{
  "name": "towel-txt",
  "version": "0.1.0",
  "description": "Convert Markdown into printable HTML and PDF documents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "towel-txt": "./dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "docs/**/*.md",
    "examples/**/*.md",
    "examples/**/*.css",
    "examples/**/*.svg",
    "examples/**/*.yaml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepack": "pnpm build",
    "perf:smoke": "node scripts/performance-smoke.mjs",
    "release:check": "node scripts/release-check.mjs",
    "security:audit": "pnpm audit --audit-level high",
    "smoke:package": "node scripts/package-smoke.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "markdown",
    "print",
    "html",
    "document",
    "cli"
  ],
  "author": "Kaleab Kali",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaleab-kali/towel.txt.git"
  },
  "bugs": {
    "url": "https://github.com/kaleab-kali/towel.txt/issues"
  },
  "homepage": "https://github.com/kaleab-kali/towel.txt#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.21",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "markdown-it": "^14.2.0",
    "yaml": "^2.9.0"
  }
}
